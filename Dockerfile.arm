# Stage 1: Build
FROM golang:1.24-alpine AS builder
RUN apk add --no-cache gcc musl-dev libpcap-dev
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=1 GOOS=linux GOARCH=arm64 go build -o net-oracle .

# Stage 2: Runtime
FROM alpine:latest
RUN apk add --no-cache libpcap
WORKDIR /root/
COPY --from=builder /app/net-oracle .
ENTRYPOINT ["./net-oracle"]